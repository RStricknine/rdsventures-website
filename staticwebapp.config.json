{
  "platform": {
    "apiRuntime": "node:20"
  },
  "routes": [
{
  "route": "/api/workorders/photos/view",
  "allowedRoles": ["anonymous"]
},
{
  "route": "/api/workorders/photos/list",
  "allowedRoles": ["authenticated"]
},
{
  "route": "/api/workorders/photos/upload",
  "allowedRoles": ["authenticated"]
},
{
  "route": "/api/workorders/photos/delete",
  "allowedRoles": ["authenticated"]
},
{
  "route": "/api/dashboard",
  "allowedRoles": ["anonymous"]
},
    {
      "route": "/",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/servicerequest.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/service-request",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/service-request-list",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/service-request-convert",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/dashboard/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}