{
  "routes": [
    {
      "route": "/dashboard*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/workorders*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/customers*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/properties*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/service-request",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]   
    },
    {
      "route": "/",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}