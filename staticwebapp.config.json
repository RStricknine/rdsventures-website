{
  "routes": [
    {
      "route": "/api/service-request",
      "allowedRoles": ["anonymous"]
    },
   {
  "route": "/api/customers*",
  "allowedRoles": ["authenticated"]
    },
    {
      "route": "/dashboard*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/dashboard*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/me",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}
