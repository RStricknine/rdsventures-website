
{
  "routes": [
    {
      "route": "/",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/service-request",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/service-request/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/service-request",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/dashboard/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/workorders/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/customers/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/properties/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}
